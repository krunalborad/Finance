generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     String
  active   Boolean @default(true)
}

model Record {
  id        Int      @id @default(autoincrement())
  amount    Float
  type      String
  category  String
  notes     String?
  date      DateTime @default(now())
}